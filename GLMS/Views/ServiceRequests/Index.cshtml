@model IEnumerable<GLMS.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<h1 class="mb-3">Service Requests</h1>

<p>
    <a asp-action="Create" class="btn home-btn-primary">Create New</a>
</p>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Contract</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>@Html.DisplayNameFor(model => model.CostUSD)</th>
            <th>@Html.DisplayNameFor(model => model.CostZAR)</th>
            <th>@Html.DisplayNameFor(model => model.CreatedDate)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Contract?.Description</td>
                <td>@item.Description</td>
                <td>@item.CostUSD</td>
                <td>@item.CostZAR</td>
                <td>@item.CreatedDate.ToShortDateString()</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ServiceRequestId" class="text-success fw-semibold">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.ServiceRequestId" class="text-success fw-semibold">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.ServiceRequestId" class="text-danger fw-semibold">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>