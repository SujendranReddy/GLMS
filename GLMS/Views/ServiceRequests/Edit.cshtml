@model GLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit Service Request";
}

<h1 class="mb-3">Edit Service Request</h1>

<h4 class="text-success">Request Details</h4>
<hr class="border-success" />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ServiceRequestId" />

            <div class="form-group mb-3">
                <label asp-for="ContractId" class="fw-semibold"></label>
                <select asp-for="ContractId" class="form-control border-success" asp-items="ViewBag.ContractId"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="fw-semibold"></label>
                <input asp-for="Description" class="form-control border-success" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CostUSD" class="fw-semibold"></label>
                <input asp-for="CostUSD" class="form-control border-success" />
                <span asp-validation-for="CostUSD" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CostZAR" class="fw-semibold"></label>
                <input asp-for="CostZAR" class="form-control border-success" />
                <span asp-validation-for="CostZAR" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CreatedDate" class="fw-semibold"></label>
                <input asp-for="CreatedDate" class="form-control border-success" />
                <span asp-validation-for="CreatedDate" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn home-btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="text-success fw-semibold">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}