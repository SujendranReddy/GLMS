@{
    ViewData["Title"] = "Home";
}

<div class="home-video-wrapper">

    <!-- The background video to play in a loop -->
    <video autoplay muted loop playsinline class="home-video">

        <!-- The video is stored in wwwroot/videos -->
        <source src="/videos/15305863_3840_2160_24fps.mp4"
                type="video/mp4">

    </video>


    <div class="home-overlay"></div>


    <div class="home-content">

        <h1 class="home-title">
            Global Logistics Management System
        </h1>

        <p class="home-subtitle">

            Manage clients, contracts, and service requests
            across global operations.

        </p>


        <div class="home-buttons">

            <a asp-controller="Clients"
               asp-action="Index"
               class="btn home-btn-primary">

                Clients

            </a>


            <a asp-controller="Contracts"
               asp-action="Index"
               class="btn home-btn-outline">

                Contracts

            </a>


            <a asp-controller="ServiceRequests"
               asp-action="Index"
               class="btn home-btn-outline">

                Service Requests

            </a>

        </div>

    </div>

</div>