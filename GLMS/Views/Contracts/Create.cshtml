@model GLMS.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
}

<h1 class="mb-3">Create Contract</h1>

<h4 class="text-success">Contract Details</h4>

<hr class="border-success" />


<div class="row">

    <div class="col-md-4">

        <form asp-action="Create" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>


            <div class="form-group mb-3">

                <label asp-for="ClientId"
                       class="fw-semibold"></label>

                <select asp-for="ClientId"
                        class="form-control border-success"
                        asp-items="ViewBag.ClientId"></select>

            </div>


            <div class="form-group mb-3">

                <label asp-for="Description"
                       class="fw-semibold"></label>

                <input asp-for="Description"
                       class="form-control border-success" />

                <span asp-validation-for="Description"
                      class="text-danger"></span>

            </div>


            <div class="form-group mb-3">

                <label asp-for="Cost"
                       class="fw-semibold"></label>

                <input asp-for="Cost"
                       class="form-control border-success" />

                <span asp-validation-for="Cost"
                      class="text-danger"></span>

            </div>


            <div class="form-group mb-3">

                <label asp-for="Status"
                       class="fw-semibold"></label>

                <select asp-for="Status"
                        class="form-control border-success"
                        asp-items="Html.GetEnumSelectList<GLMS.Enums.ContractStatus>()"></select>

                <span asp-validation-for="Status"
                      class="text-danger"></span>

            </div>


            <div class="form-group mb-3">

                <label class="fw-semibold">

                    Signed Agreement (PDF)

                </label>

                <input type="file"
                       name="pdfFile"
                       class="form-control border-success"
                       accept=".pdf" />

            </div>


            <div class="form-group mt-3">

                <input type="submit"
                       value="Create"
                       class="btn home-btn-primary" />

            </div>

        </form>

    </div>

</div>


<div class="mt-3">

    <a asp-action="Index"
       class="text-success fw-semibold">

        Back to List

    </a>

</div>


@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}