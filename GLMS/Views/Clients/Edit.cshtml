@model GLMS.Models.Client

@{
    ViewData["Title"] = "Edit Client";
}

<h1 class="mb-3">Edit Client</h1>

<h4 class="text-success">Client Details</h4>
<hr class="border-success" />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ClientId" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label fw-semibold"></label>
                <input asp-for="Name" class="form-control border-success" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label fw-semibold"></label>
                <input asp-for="Email" class="form-control border-success" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PhoneNumber" class="control-label fw-semibold"></label>
                <input asp-for="PhoneNumber" class="form-control border-success" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Region" class="control-label fw-semibold"></label>
                <input asp-for="Region" class="form-control border-success" />
                <span asp-validation-for="Region" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn home-btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="text-success fw-semibold">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}