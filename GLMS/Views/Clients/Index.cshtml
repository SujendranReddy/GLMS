@model IEnumerable<GLMS.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<h1 class="mb-3">Clients</h1>

<p>
    <a asp-action="Create" class="btn home-btn-primary">Create New</a>
</p>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Email)</th>
            <th>@Html.DisplayNameFor(model => model.PhoneNumber)</th>
            <th>@Html.DisplayNameFor(model => model.Region)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                <td>@Html.DisplayFor(modelItem => item.Region)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ClientId" class="text-success fw-semibold">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.ClientId" class="text-success fw-semibold">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.ClientId" class="text-danger fw-semibold">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>